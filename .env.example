# ============================================================
#  بوت مجتمع A7MED — متغيرات البيئة المطلوبة
#  A7MED Community Bot — Required Environment Variables
# ============================================================
#
#  انسخ هذا الملف إلى .env وأضف قيمك الخاصة
#  Copy this file to .env and fill in your own values
#
#  على Railway: أضف هذه المتغيرات في
#  Settings → Variables داخل لوحة تحكم المشروع
# ============================================================

# ----------------------------------------------------------
# 🔑 إعدادات البوت الأساسية — Core Bot Settings
# ----------------------------------------------------------

# توكن البوت من Discord Developer Portal
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# معرّف تطبيق البوت (Client ID) من Developer Portal
# Bot application/client ID from Developer Portal
DISCORD_CLIENT_ID=your_client_id_here

# معرّف السيرفر الرئيسي (Guild ID)
# Main server/guild ID — right-click server → Copy Server ID
GUILD_ID=your_guild_id_here

# ----------------------------------------------------------
# 👑 معرّفات المستخدمين — User IDs
# ----------------------------------------------------------

# معرّف حساب المالك A7MED على ديسكورد
# Discord user ID of the bot owner (A7MED)
OWNER_ID=your_owner_discord_id_here

# معرّف حساب المطور 9ATTOS على ديسكورد
# Discord user ID of the developer (9ATTOS)
DEV_ID=your_dev_discord_id_here

# ----------------------------------------------------------
# 🎭 معرّفات الرتب — Role IDs
# ----------------------------------------------------------

# معرّف رتبة الأدمن في السيرفر
# Admin role ID — right-click role → Copy Role ID
ADMIN_ROLE_ID=your_admin_role_id_here

# معرّف الرتبة التي تُمنح تلقائياً عند الانضمام
# Auto-role ID — role given automatically when a member joins
AUTO_ROLE_ID=your_auto_role_id_here

# ----------------------------------------------------------
# 📢 معرّفات القنوات — Channel IDs
# ----------------------------------------------------------

# معرّف قناة الترحيب بالأعضاء الجدد
# Welcome channel ID — right-click channel → Copy Channel ID
WELCOME_CHANNEL_ID=your_welcome_channel_id_here

# ----------------------------------------------------------
# ⚙️ إعدادات البوت — Bot Settings
# ----------------------------------------------------------

# البادئة المستخدمة للأوامر (الافتراضي: !)
# Command prefix (default: !)
PREFIX=!

# ----------------------------------------------------------
# 💰 إعدادات الاقتصاد — Economy Settings
# ----------------------------------------------------------

# الرصيد الابتدائي للأعضاء الجدد
# Starting balance for new members
STARTING_BALANCE=1000

# المكافأة اليومية
# Daily reward amount
DAILY_REWARD=500

# خصم الإجابة الخاطئة في الأسئلة
# Penalty for wrong quiz answers
QUIZ_WRONG_PENALTY=50

# ----------------------------------------------------------
# 📈 إعدادات نظام XP — XP System Settings
# ----------------------------------------------------------

# الحد الأدنى لنقاط XP لكل رسالة
# Minimum XP earned per message
XP_PER_MESSAGE_MIN=5

# الحد الأقصى لنقاط XP لكل رسالة
# Maximum XP earned per message
XP_PER_MESSAGE_MAX=15

# مكافأة ترقية المستوى بالعملات
# Coin reward for leveling up
LEVEL_UP_REWARD=300
